# EA Software Solutions - Apache config for Hostinger shared hosting
# Replaces the Vercel security headers and adds SPA routing + caching.
# Lives in public_html/ alongside index.html and assets/.

# --- SPA routing -------------------------------------------------------------
# React Router owns /services, /projects, /about, etc. Those paths do not exist
# as files on disk, so serve index.html for anything that is not a real file.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

  # Serve real files and directories as-is
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Everything else goes to the SPA entry point
  RewriteRule ^ index.html [L]
</IfModule>

# --- Security headers --------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

  # Hashed build assets are immutable; index.html must never be cached or
  # visitors keep loading a stale bundle after a deploy.
  <FilesMatch "\.(js|css|woff2|png|jpg|jpeg|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# --- Compression -------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Hardening ---------------------------------------------------------------
Options -Indexes

<FilesMatch "^\.(env|git|gitignore)">
  Require all denied
</FilesMatch>

ErrorDocument 404 /index.html
